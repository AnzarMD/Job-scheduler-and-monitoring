# Copy this file to secrets.yaml and fill in your base64-encoded values
# Generate: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes("your-value"))
# NEVER commit secrets.yaml — it is in .gitignore
apiVersion: v1
kind: Secret
metadata:
  name: cloudflow-secrets
  namespace: cloudflow
type: Opaque
data:
  DB_USERNAME: <base64-encoded-username>
  DB_PASSWORD: <base64-encoded-password>
  REDIS_PASSWORD: <base64-encoded-redis-password>
  JWT_SECRET: <base64-encoded-jwt-secret>